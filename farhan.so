#!/usr/bin/env python3
import sys,os,base64,zlib,tempfile,subprocess
C=""
def m():
 t=tempfile.NamedTemporaryFile(mode='w',suffix='.py',delete=False)
 t.write(zlib.decompress(base64.b64decode(C)).decode())
 t.close()
 os.chmod(t.name,0o755)
 r=subprocess.run([sys.executable,t.name]+sys.argv[1:])
 os.unlink(t.name)
 return r.returncode
if __name__=="__main__":sys.exit(m())
